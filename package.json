{
  "name": "@scheduler-systems/demo-studio",
  "version": "0.1.0",
  "description": "AI-powered software demo video recorder with zoom effects, cursor smoothing, and MCP integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "demo-studio": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "mcp": "node dist/mcp/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^8.0.1",
    "p-queue": "^8.0.1",
    "zod": "^3.22.4",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "chokidar": "^3.5.3",
    "fluent-ffmpeg": "^2.1.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "sharp": "^0.33.2",
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "screen-recording",
    "demo-video",
    "video-editing",
    "mcp",
    "ai-agent",
    "zoom-effects",
    "cursor-smoothing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Scheduler-Systems/demo-studio.git"
  },
  "author": "Scheduler Systems",
  "license": "MIT"
}
